{
  "expo": {
    "name": "KHỞI NGUYÊN LAND",
    "slug": "khoi-nguyen-land",
    "version": "0.1.3",
    "icon": "./assets/images/icons/app-icon.png",
    "orientation": "portrait",
    "scheme": "BDS",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icons/app-icon.png",
      "bundleIdentifier": "com.duongkhongkich.nhmBDSapp",
      "buildNumber": "`2",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Ứng dụng cần quyền vị trí để xác nhận chấm công tại văn phòng.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.duongkhongkich.nhmBDSapp",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#950100"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ứng dụng cần quyền vị trí để xác nhận chấm công tại văn phòng."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần quyền chọn ảnh để gửi hồ sơ KYC."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59c985a9-fabc-4851-8102-8d1ec0cbcfc6"
      }
    },
    "owner": "duongkhongkich"
  }
}
